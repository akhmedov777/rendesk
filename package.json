{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "rendesk-desktop",
  "description": "Rendesk Desktop (Beta) - AI-powered development tool",
  "private": true,
  "version": "1.0.0-beta.2",
  "type": "module",
  "packageManager": "bun@1.3.10",
  "scripts": {
    "dev": "bun run --cwd packages/desktop dev",
    "build": "bun run --cwd packages/desktop build",
    "dist": "bun run --cwd packages/desktop dist",
    "dist:mac": "bun run --cwd packages/desktop dist:mac",
    "dist:win": "bun run --cwd packages/desktop dist:win",
    "test:desktop": "bun run --cwd packages/desktop test",
    "typecheck": "bun run --cwd packages/desktop typecheck",
    "preview": "bun run --cwd packages/desktop preview"
  },
  "workspaces": {
    "packages": [
      "packages/*",
      "packages/sdk/js"
    ],
    "catalog": {
      "@types/bun": "1.3.9",
      "@kobalte/core": "0.13.11",
      "@types/luxon": "3.7.1",
      "@types/node": "22.13.9",
      "@tsconfig/node22": "22.0.2",
      "@tsconfig/bun": "1.0.9",
      "@pierre/diffs": "1.1.0-beta.18",
      "@solid-primitives/storage": "4.3.3",
      "@tailwindcss/vite": "4.1.11",
      "diff": "8.0.2",
      "echarts": "5.6.0",
      "dompurify": "3.3.1",
      "fuzzysort": "3.1.0",
      "luxon": "3.6.1",
      "marked": "17.0.1",
      "marked-shiki": "1.2.1",
      "typescript": "5.8.2",
      "@typescript/native-preview": "7.0.0-dev.20251207.1",
      "zod": "4.1.8",
      "remeda": "2.26.0",
      "shiki": "3.20.0",
      "solid-list": "0.3.0",
      "tailwindcss": "4.1.11",
      "virtua": "0.42.3",
      "vite": "7.1.4",
      "@solidjs/meta": "0.29.4",
      "@solidjs/router": "0.15.4",
      "solid-js": "1.9.10",
      "vite-plugin-solid": "2.11.10"
    }
  },
  "devDependencies": {
    "@tsconfig/bun": "catalog:",
    "@typescript/native-preview": "catalog:",
    "prettier": "3.6.2",
    "typescript": "catalog:"
  },
  "dependencies": {
    "@opencode-ai/sdk": "workspace:*"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/renvel/rendesk"
  },
  "license": "MIT",
  "prettier": {
    "semi": false,
    "printWidth": 120
  },
  "trustedDependencies": [
    "esbuild",
    "protobufjs"
  ],
  "overrides": {
    "@types/bun": "catalog:",
    "@types/node": "catalog:"
  }
}
