{
  "name": "@rendesk/desktop",
  "private": true,
  "version": "1.0.0-beta.2",
  "description": "Rendesk for macOS and Windows",
  "productName": "Rendesk",
  "type": "module",
  "main": "dist/electron/main.js",
  "author": "Anomaly Co",
  "license": "MIT",
  "scripts": {
    "typecheck": "tsgo -b",
    "test": "bun test ./src/electron/provider-auth-store.test.ts",
    "dev": "bun ./scripts/dev.ts",
    "build": "bun run typecheck && vite build && bun ./scripts/build-electron.ts",
    "preview": "vite preview --host 127.0.0.1 --port 4173",
    "pack": "bun run build && bun x electron-builder --dir",
    "dist": "bun run build && bun x electron-builder",
    "dist:mac": "bun run build && bun x electron-builder --mac dmg zip",
    "dist:win": "bun run build && bun x electron-builder --win nsis --x64",
    "download:pyodide": "bun scripts/download-pyodide.ts"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.66",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@rendesk/app": "workspace:*",
    "@rendesk/sdk": "workspace:*",
    "@rendesk/ui": "workspace:*",
    "@solidjs/router": "catalog:",
    "@solid-primitives/i18n": "2.2.1",
    "@solid-primitives/storage": "catalog:",
    "@solidjs/meta": "catalog:",
    "@types/bun": "catalog:",
    "@typescript/native-preview": "catalog:",
    "electron": "^38.1.0",
    "electron-builder": "^26.0.12",
    "localtunnel": "^2.0.2",
    "solid-js": "catalog:",
    "typescript": "~5.6.2",
    "vite": "catalog:"
  }
}
